<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.XNetZT" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/xnet_primary</item>
        <item name="colorPrimaryVariant">@color/xnet_primary_dark</item>
        <item name="colorOnPrimary">@color/xnet_background</item>
        <item name="colorSecondary">@color/xnet_accent</item>
        <item name="colorSecondaryVariant">@color/xnet_accent</item>
        <item name="colorOnSecondary">@color/xnet_background</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/xnet_background</item>
        <item name="greyText">@color/grey_text</item>
        <item name="lightGreyText">@color/light_grey_text</item>
        <item name="tableRowGrey">@color/table_row_grey</item>
    </style>

    <style name="Theme.XNetZT.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.XNetZT.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.XNetZT.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
